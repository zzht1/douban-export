# Douban Insight 环境配置
# 复制此文件为 .env 并填入你的配置

# LLM API 配置（OpenAI 兼容格式）
# 支持 OpenAI / DeepSeek / 其他兼容 API
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# DeepSeek 示例:
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 豆瓣 Cookie（可选）
# 仅用于本地爬取/调试脚本。不要把真实 Cookie 提交到仓库。
DOUBAN_COOKIE=

# 服务器配置
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
